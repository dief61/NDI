# ndi – Umgebungsvariablen (diese Datei als .env ins Projektwurzelverzeichnis kopieren)
# .env selbst NIEMALS ins Git committen – nur .env.example!

# PostgreSQL
POSTGRES_USER=mnr
POSTGRES_PASSWORD=mnr_pg_password
POSTGRES_DB=mnr_db
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=mnr_admin
MINIO_ROOT_PASSWORD=ndi_minio_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DEFAULT_BUCKET=mnr-artefakte

# Apache Tika
TIKA_PORT=9998

# Allgemein
PROJECT_NAME=ndi
